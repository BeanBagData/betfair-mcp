# Betfair credentials — required.
# Paste your working values into a file named `.env` in this directory.
# .env is gitignored; never commit real values.
BETFAIR_USERNAME=me@example.com
BETFAIR_PASSWORD=change-me
BETFAIR_APP_KEY=change-me

# Paper mode (default: true). Set to false ONLY when you intend to bet real money.
# When true, place_lay_bet / place_back_bet / cancel_order return simulated responses
# and do not call Betfair.
PAPER_MODE=true

# Daily paper-bet scheduler (runs only while PAPER_MODE=true and the MCP server is running)
PAPER_AUTOBET_ENABLED=true
PAPER_AUTOBET_TIME=08:30
PAPER_AUTOBET_TZ=Australia/Melbourne
PAPER_AUTOBET_MAX_ATTEMPTS=3
PAPER_AUTOBET_RETRY_MINUTES=30

# Optional shared state paths. The launchd installer writes absolute values
# under ~/Library/Application Support/BetfairMCP/state.
# PAPER_BET_LOG_PATH=/absolute/path/bet_log.json
# BETTING_HISTORY_PATH=/absolute/path/betting_history.json
# PAPER_AUTOBET_STATE_PATH=/absolute/path/paper_autobet_state.json
# ORDERS_CSV_PATH=/absolute/path/orders_agent.csv
